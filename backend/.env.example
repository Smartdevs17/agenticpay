NODE_ENV=development
PORT=3001
CORS_ALLOWED_ORIGINS=http://localhost:3000
JOBS_ENABLED=true
QUEUE_ENABLED=true
STELLAR_NETWORK=testnet
RATE_LIMIT_FREE=100
RATE_LIMIT_PRO=300
RATE_LIMIT_ENTERPRISE=1000
RATE_LIMIT_WINDOW_MS=900000
COMPRESSION_THRESHOLD=1024

# Token Bucket Rate Limiting
# REDIS_URL=redis://localhost:6379
# RATE_LIMIT_BURST_FREE=10
# RATE_LIMIT_BURST_PRO=50
# RATE_LIMIT_BURST_ENTERPRISE=200
# RATE_LIMIT_REFILL_FREE=1
# RATE_LIMIT_REFILL_PRO=5
# RATE_LIMIT_REFILL_ENTERPRISE=20

# IP Allowlist (comma-separated CIDR ranges)
# IP_ALLOWLIST=10.0.0.0/8,192.168.1.0/24
# IP_ALLOWLIST_ENABLED=false
# IP_ALLOWLIST_BYPASS_ENABLED=false
# IP_ALLOWLIST_BYPASS_EXPIRY_MS=1800000

# Stripe card payments
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
